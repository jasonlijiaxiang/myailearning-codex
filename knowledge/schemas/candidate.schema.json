{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/schemas/knowledge-candidate.schema.json",
  "title": "Knowledge candidate",
  "type": "object",
  "required": [
    "id",
    "title",
    "kind",
    "summary",
    "capturedTurnIds",
    "contentHash",
    "status",
    "visibility",
    "sensitivity",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._/-]{1,127}$"
    },
    "title": { "type": "string", "minLength": 1 },
    "kind": {
      "enum": ["concept", "procedure", "decision", "failure-pattern", "question", "source-update"]
    },
    "moduleId": { "type": ["string", "null"], "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "capturedTurnIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^t_[0-9a-f]{32}$" }
    },
    "sourceIds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "claimIds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "integratedResultIds": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(claim|module|source|release):[a-z0-9][a-z0-9._/-]{1,127}$"
      }
    },
    "status": {
      "enum": ["pending", "needs-evidence", "ready", "integrated", "rejected"]
    },
    "visibility": { "enum": ["private", "public-candidate"] },
    "sensitivity": { "enum": ["none", "review", "restricted"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "contentHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "decision": { "type": "string" }
  },
  "additionalProperties": false
}
