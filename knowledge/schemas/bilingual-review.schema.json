{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloud-ai-presales-fieldbook.local/schemas/bilingual-review.schema.json",
  "title": "Bilingual content review",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "reviewId", "scope", "stage", "deterministic", "rubric", "findings", "verdict", "blockClass", "attempt", "nextStage"],
  "allOf": [
    {
      "if": { "properties": { "verdict": { "const": "PASS" } }, "required": ["verdict"] },
      "then": {
        "properties": {
          "deterministic": { "items": { "properties": { "status": { "const": "PASS" } } } },
          "blockClass": { "const": "NONE" },
          "nextStage": { "const": "publish-candidate" }
        }
      }
    },
    {
      "if": { "properties": { "deterministic": { "contains": { "properties": { "status": { "const": "FAIL" } }, "required": ["status"] } } }, "required": ["deterministic"] },
      "then": {
        "properties": {
          "verdict": { "const": "BLOCK" },
          "blockClass": { "const": "ENGINEERING" },
          "nextStage": { "const": "engineering" }
        }
      }
    },
    {
      "if": { "properties": { "blockClass": { "not": { "const": "NONE" } } }, "required": ["blockClass"] },
      "then": { "properties": { "verdict": { "const": "BLOCK" } } }
    },
    {
      "if": { "properties": { "verdict": { "const": "BLOCK" } }, "required": ["verdict"] },
      "then": {
        "properties": {
          "blockClass": { "not": { "const": "NONE" } },
          "nextStage": { "enum": ["ultra-exception", "engineering"] }
        }
      }
    }
  ],
  "properties": {
    "schemaVersion": { "const": "bilingual-review/v1" },
    "reviewId": { "type": "string", "pattern": "^br-[a-z0-9-]+$" },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["moduleId", "locale", "objectType", "objectId", "zhContentHash", "enContentHash", "termIds", "sourceIds"],
      "properties": {
        "moduleId": { "type": "string" },
        "locale": { "const": "en" },
        "objectType": { "enum": ["module", "section", "question", "evidence", "term", "source"] },
        "objectId": { "type": ["string", "null"] },
        "zhContentHash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "enContentHash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "termIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "sourceIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "stage": { "enum": ["xhigh-author", "xhigh-semantic", "xhigh-language", "ultra-exception"] },
    "deterministic": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gateId", "status", "evidence"],
        "properties": {
          "gateId": { "type": "string" },
          "status": { "enum": ["PASS", "FAIL"] },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "rubric": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 1, "maximum": 5 },
      "required": ["semanticFidelity", "mechanismAccuracy", "boundaryPreservation", "evidenceFaithfulness", "technicalEnglish", "presalesUsability"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "fieldPath", "explanation", "sourceIds", "autoRevisable"],
        "properties": {
          "code": { "type": "string" },
          "severity": { "enum": ["minor", "major", "critical"] },
          "fieldPath": { "type": "string" },
          "explanation": { "type": "string" },
          "sourceIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "autoRevisable": { "type": "boolean" }
        }
      }
    },
    "verdict": { "enum": ["PASS", "REVISE", "BLOCK"] },
    "blockClass": { "enum": ["NONE", "ENGINEERING", "EVIDENCE", "EDITORIAL_DISPUTE", "DYNAMIC_FACT"] },
    "attempt": { "type": "integer", "minimum": 1 },
    "nextStage": { "enum": ["publish-candidate", "xhigh-rewrite", "ultra-exception", "engineering"] }
  }
}
